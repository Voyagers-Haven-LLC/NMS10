# Copy this file to backend/.env (or to .env at the repo root for compose)
# and fill in real values. The .env files are gitignored — never commit them.
#
# Any scraper-credential var below set to "STUB" disables that scraper;
# it logs a warning and shows up in /api/admin/scraper-status with
# auth_state='stub-credentials' until real creds land.

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
NMS10_ADMIN_PASSWORD=changeme
# Generate with: openssl rand -base64 48
NMS10_JWT_SECRET=

# ---------------------------------------------------------------------------
# Bot wiring (only matters in dev — compose overrides this to nms10-bot:9000)
# ---------------------------------------------------------------------------
NMS10_BOT_WEBHOOK_URL=http://127.0.0.1:9000/notify

# ---------------------------------------------------------------------------
# Public site URL (used in /nms10-status embed and approval links)
# ---------------------------------------------------------------------------
NMS10_SITE_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Scraper behavior
# ---------------------------------------------------------------------------
# false = scraped posts queue for moderation (recommended).
# true  = auto-publish to /socials. Only flip if you trust the per-source
#         filters fully.
NMS10_SCRAPER_AUTO_PUBLISH=false

# Public IPs are limited to this rate on POST /api/submissions/*.
# The Discord bot bypasses via X-NMS10-Bot-Secret automatically.
NMS10_SUBMISSION_RATE_LIMIT=5/hour

# ---------------------------------------------------------------------------
# Steam (optional — public endpoint we hit doesn't actually require a key)
# ---------------------------------------------------------------------------
STEAM_API_KEY=

# ---------------------------------------------------------------------------
# Scraper credentials (set to STUB until you have real values)
# ---------------------------------------------------------------------------

# YouTube Data API v3 — https://console.cloud.google.com/
# Enable "YouTube Data API v3", create an API key under Credentials.
# Free quota 10k units/day; we use ~4.8k at the default 30-min schedule.
YOUTUBE_API_KEY=STUB

# Reddit script app — https://www.reddit.com/prefs/apps
# "Create another app" → pick "script" → note client_id (under app name)
# and client_secret. The user-agent is REQUIRED by Reddit's API rules.
REDDIT_CLIENT_ID=STUB
REDDIT_CLIENT_SECRET=STUB
REDDIT_USER_AGENT=nms10-aggregator/1.0 (by /u/your-reddit-username)

# Twitter / X — auth_token cookie from a logged-in burner account.
# DevTools → Application → Cookies → x.com → copy auth_token value.
TWITTER_AUTH_TOKEN=STUB

# Instagram — burner account credentials. The burner should be 2+ weeks
# old before first scrape, used "normally" on a personal device — NOT the
# Pi's IP — to avoid Instagram's new-account bot detection.
INSTAGRAM_USERNAME=STUB
INSTAGRAM_PASSWORD=STUB
