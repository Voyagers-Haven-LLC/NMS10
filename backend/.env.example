# Copy to backend/.env and fill in. .env files are gitignored.
#
# Any var below set to "STUB" disables its scraper; the scraper logs a
# warning and shows up in /admin/scraper-status with auth_state='stub-credentials'.

# Admin / auth
NMS10_ADMIN_PASSWORD=changeme
NMS10_JWT_SECRET=

# Bot wiring
NMS10_BOT_WEBHOOK_URL=http://127.0.0.1:9000/notify

# Scraper behavior
NMS10_SCRAPER_AUTO_PUBLISH=true

# Steam (optional — endpoint we hit doesn't actually require a key)
STEAM_API_KEY=

# YouTube Data API v3 — https://console.cloud.google.com/
YOUTUBE_API_KEY=STUB

# Reddit script app — https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=STUB
REDDIT_CLIENT_SECRET=STUB
REDDIT_USER_AGENT=nms10-aggregator/1.0 (by /u/Parker1920)

# Twitter / X — auth_token cookie from a logged-in burner account
TWITTER_AUTH_TOKEN=STUB

# Instagram — burner account credentials. Aged 2+ weeks before first use.
INSTAGRAM_USERNAME=STUB
INSTAGRAM_PASSWORD=STUB
