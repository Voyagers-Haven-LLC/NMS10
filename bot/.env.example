# Copy to .env and fill in. .env is gitignored.

# Required for live Discord:
NMS10_DISCORD_BOT_TOKEN=

# Comma-separated Discord user IDs allowed to run /bot-reload
NMS10_BOT_ADMINS=

# Backend API. Default works for local dev with both processes on the host.
NMS10_BACKEND_URL=http://localhost:8000

# Webhook listener (loopback only by design)
NMS10_BOT_WEBHOOK_HOST=127.0.0.1
NMS10_BOT_WEBHOOK_PORT=9000

# Path to per-server channel config
NMS10_BOT_SERVERS_FILE=config/servers.yaml
